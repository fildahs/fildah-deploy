# Copy this file to deploy/.env on the VPS and fill in real secrets.

# Caddy / TLS
CADDY_ACME_EMAIL=admin@fildah.com

# Django
SECRET_KEY=change-this-to-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=api.fildah.com
ALLOWED_ORIGINS=https://www.fildah.com,https://rxchat.fildah.com
FILDAH_ORIGINS=https://www.fildah.com
RXCHAT_ORIGINS=https://rxchat.fildah.com
SECURE_PROXY_SSL_ENABLED=True
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_SAMESITE=None
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_SAMESITE=None
DATABASE_CONN_MAX_AGE=600
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Postgres container
POSTGRES_DB=fildah
POSTGRES_USER=fildah
POSTGRES_PASSWORD=change-this-postgres-password

# Qdrant container
QDRANT_API_KEY=change-this-qdrant-api-key
QDRANT_COLLECTION=RxChat
QDRANT_CLOUD_INFERENCE=False
QDRANT_VECTOR_SIZE=1024
QDRANT_BINARY_QUANTIZATION=True
# Leave blank for dense-first self-hosted launch; set qdrant/bm25 after confirming BM25 on the target collection.
QDRANT_SPARSE_MODEL=

# Container images
FILDAH_API_IMAGE=ghcr.io/fildahs/fildah-api:main
FILDAH_WEB_IMAGE=ghcr.io/fildahs/fildah-web:main
RXCHAT_WEB_IMAGE=ghcr.io/fildahs/rxchat-web:main

# Frontend builds
FRONTEND_API_BASE_URL=https://api.fildah.com
RXCHAT_UNDER_CONSTRUCTION=false

# AI providers
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Email / OAuth / data acquisition
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@fildah.com
BREVO_REPLY_TO_EMAIL=support@fildah.com
BREVO_SENDER_NAME_FILDAH=Fildah
BREVO_SENDER_NAME_RXCHAT=RxChat
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OPENFDA_API_KEY=

